{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/group$",
      "dest": "/group/index.html"
    },
    {
      "src": "/group/(.*)",
      "dest": "/group/index.html"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
