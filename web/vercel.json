{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/assets/node_modules/.*/([^/]+\\.ttf)$",
      "dest": "/assets/fonts/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/_expo/(.*)",
      "dest": "/_expo/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
