{
  "license": "0BSD",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "lint:strict": "eslint . --ext .js,.jsx --max-warnings=0",
    "format": "prettier --write '**/*.{js,jsx,json}'",
    "format:check": "prettier --check '**/*.{js,jsx,json}'",
    "dead-code": "knip",
    "audit": "npm audit --audit-level=high",
    "secrets": "secretlint '**/*.{js,jsx,json}'",
    "validate-vibe": "node scripts/validate-vibe.js",
    "review": "echo '\\n=== FORKIT REVIEW SUITE ===' && echo '\\n--- 1/6 Linting ---' && npm run lint && echo '\\n--- 2/6 Formatting ---' && npm run format:check && echo '\\n--- 3/6 Dead Code ---' && npm run dead-code && echo '\\n--- 4/6 Dependency Audit ---' && npm run audit && echo '\\n--- 5/6 Secret Scan ---' && npm run secrets && echo '\\n--- 6/6 Vibe Check ---' && npm run validate-vibe && echo '\\n=== ALL CHECKS PASSED ==='",
    "review:fix": "npm run lint:fix && npm run format"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo/app-integrity": "~0.1.10",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.2.0",
    "expo": "~54.0.31",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "^14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.12.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "name": "AppFiles",
  "version": "1.0.0",
  "devDependencies": {
    "@secretlint/core": "^11.3.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^0.25.1",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "secretlint": "^11.3.1"
  }
}
